# Mizan Wealth - Production Environment Variables Template

# 1. API Key for precious metals prices API (optional, defaults to fallback rates if empty)
# Get a key from metalpriceapi.com or similar if required.
METAL_PRICE_API_KEY=your_metal_price_api_key_here

# 2. Google Gemini API Key for Shariah-compliant Advisor Insights (optional, uses local heuristic rules engine if empty)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# Alternatively:
# GOOGLE_API_KEY=your_google_api_key_here
